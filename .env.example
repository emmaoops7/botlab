# ──────────────────────────────────────────────────────────────
# Tuya Smart Home — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets to version control.
# ──────────────────────────────────────────────────────────────

# ── Recommended: Tuya Cloud OpenAPI (Access ID / Secret) ─────
# Used by TuyaCloudAPI for HMAC-SHA256 signed requests.
# Required for: IR control, Cloud Development APIs (/v1.0/token, /v2.0/...).
# Get these from https://iot.tuya.com → Cloud → Your Project → Authorization Key.
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=

# Data-center endpoint — pick the one matching your Tuya IoT project region:
#   China:          https://openapi.tuyacn.com
#   US West:        https://openapi.tuyaus.com
#   Central Europe: https://openapi.tuyaeu.com
#   India:          https://openapi.tuyain.com
#   US East:        https://openapi-ueaz.tuyaus.com
#   Western Europe: https://openapi-weaz.tuyaeu.com
#   Singapore:      https://openapi-sg.iotbing.com
TUYA_ENDPOINT=https://openapi.tuyacn.com

# ── Optional: Tuya UID ───────────────────────────────────────
# Your Tuya user ID (numeric). Used by some Cloud APIs for
# user-scoped queries. Find it in IoT Platform → Users.
TUYA_UID=

# ── Legacy / Optional: 2C End-User Bearer API Key ────────────
# Used by TuyaAPI for /v1.0/end-user/... endpoints.
# Get from https://tuya.ai/ (international) or https://tuyasmart.com/ (China).
# Format: sk-<PREFIX><rest>. Region is auto-detected from prefix.
# This is the simpler route for basic device control.
TUYA_API_KEY=

# ── Optional overrides ───────────────────────────────────────
# Override auto-detected base URL for the Bearer API key route.
# TUYA_BASE_URL=https://openapi.tuyacn.com
